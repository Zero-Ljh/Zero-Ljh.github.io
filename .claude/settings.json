{
  "permissions": {
    "allow": [
      "Bash(node -c *)",
      "Bash(git *)",
      "Bash(npx --yes *)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~*)",
      "Bash(curl *| bash*)",
      "Bash(curl *| sh*)",
      "Bash(git push -f *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/bash-firewall.js",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Read|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/file-guard.js",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/lint-on-edit.js",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|MultiEdit|WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/audit-log.js",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/stop-verify.js",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
